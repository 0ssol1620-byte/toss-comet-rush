{
  "name": "toss-comet-rush",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A high-retention Apps in Toss WebView arcade game built with Phaser.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b",
    "build": "node ./node_modules/typescript/bin/tsc -b && node scripts/build.mjs",
    "build:vite": "node ./node_modules/typescript/bin/tsc -b && vite build",
    "export:direct": "node scripts/export-direct.mjs",
    "verify:layout": "node scripts/verify-layout.mjs",
    "verify:render": "node scripts/verify-render.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "ait:build": "ait build",
    "ait:dev": "ait dev"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "2.4.7",
    "@vitejs/plugin-react": "6.0.1",
    "phaser": "4.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
